# ============================================================
# FHDAN FLEET HUB - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# See docs/setup.md for full instructions on where to get each value.
# ============================================================

# ----------------------------
# SUPABASE (Required)
# ----------------------------
# From: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ----------------------------
# RESEND EMAIL (Required for vouchers & alerts)
# ----------------------------
# From: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@fhdantourism.co.za
RESEND_FROM_NAME=Fhdan Tourism

# ----------------------------
# TELEGRAM (Required for internal alerts demo)
# ----------------------------
# Bot token from: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID: Send a message to your bot, then GET https://api.telegram.org/botTOKEN/getUpdates
TELEGRAM_CHAT_ID_OPS=your_operations_chat_id_here
TELEGRAM_CHAT_ID_SALES=your_sales_chat_id_here
TELEGRAM_CHAT_ID_FINANCE=your_finance_chat_id_here

# ----------------------------
# CALLMEBOT (Optional - WhatsApp alerts)
# ----------------------------
# Register at: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=+27XXXXXXXXX
CALLMEBOT_APIKEY=your_callmebot_apikey_here

# ----------------------------
# NEXT.JS (Required)
# ----------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_32_char_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ----------------------------
# APP CONFIG
# ----------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Fhdan Fleet Hub
NEXT_PUBLIC_COMPANY_NAME=Fhdan Tourism

# Supabase Storage bucket name (must match schema.sql)
NEXT_PUBLIC_VAULT_BUCKET=secure-documents

# ----------------------------
# CLOUDFLARE (Production only)
# ----------------------------
# From: https://dash.cloudflare.com → Workers & Pages → Your Project
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
